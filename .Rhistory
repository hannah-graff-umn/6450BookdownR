library(readxl)
library(ggplot2)
library(dplyr)
library(tidyverse)
# Reading in the dataset
lunga <- read.csv("C:\\Users\\hanna\\OneDrive\\Documents\\UofM\\Lung_Cancer_Research\\LCDC_harmonized_wo_SCCS_110722.csv")
lunga <- lunga %>% mutate(across(c(SummJCCStge, ADI_StateRank), as.integer)) %>%
mutate(across(c(NI_TractID, NI_BlkGrpID), as.numeric)) %>%
mutate(across(PID, as.character))
lungb <- read_excel("C:\\Users\\hanna\\OneDrive\\Documents\\UofM\\Lung_Cancer_Research\\LCDC_SCCS_harmonized_data_110722.xlsx")
lungb <- lungb %>% mutate(across(Hispanic:genotyped, as.integer))
lungb$UWisc_ADI_NationalRank_2019 <- as.character(lungb$UWisc_ADI_NationalRank_2019)
lung <- bind_rows(lunga, lungb)
# Cleaning up the dataset
lung <- lung %>% mutate(Case = as.factor(Case), Race=as.factor(Race), Gender=as.factor(Gender), Education_harm = as.factor(Education_harm), SmokeStatus_harm = as.factor(SmokeStatus_harm),FmHx_Cancer_harm=as.factor(FmHx_Cancer_harm), PHC_harm=as.factor(PHC_harm), UWisc_ADI_NationalRank_2019=as.numeric(UWisc_ADI_NationalRank_2019))
lung <- lung %>% mutate(
# Splitting PM25 into 4 quartiles
# Determined based on taking range and splitting into 4 equal parts
PM25 = case_when(D_PM25_2 < -11366.75 ~ 1,
D_PM25_2 >= -11366.75 & D_PM25_2 < 1177.50 ~ 2,
D_PM25_2 >= 1177.50 & D_PM25_2 < 13721.75 ~ 3,
D_PM25_2 >= 13721.75 ~ 4),
# Splitting ADI into 4 quartiles
ADI4 = case_when(UWisc_ADI_NationalRank_2019 < 25 ~ 1,
UWisc_ADI_NationalRank_2019 >= 25 & UWisc_ADI_NationalRank_2019 < 50 ~ 2,
UWisc_ADI_NationalRank_2019 >= 50 & UWisc_ADI_NationalRank_2019 < 75 ~ 3,
UWisc_ADI_NationalRank_2019 >= 75 ~ 4)) %>%
dplyr::select(c(Case, Race, Dataset_flag, Age, Gender, Education_harm, Smk_AgeStart_harm, SmokeStatus_harm, BMI, FmHx_LungCancer_harm, PHC_harm, PackYears, ADI4, PM25, SmokeDuration)) %>%
na.omit()
lung$SmokeDuration <- replace(lung$SmokeDuration, lung$SmokeDuration == 7777, 0)
lung$Race2 <- as.numeric(lung$Race)-1
lung$Case2 <- as.numeric(lung$Case)-1
lungN <- lung %>% mutate(across(c(Education_harm, SmokeStatus_harm, Dataset_flag), as.numeric))
lungN$Gender <- as.numeric(lungN$Gender)-1
lungN$PHC_harm <- as.numeric(lungN$PHC_harm)-1
# Without Hierarchical Variable
prismFull <- prism(Surv(SmokeDuration, Case2) ~ Dataset_flag + Age + Gender + Education_harm + Smk_AgeStart_harm + SmokeStatus_harm + BMI + FmHx_LungCancer_harm + PHC_harm + PackYears + ADI4 + PM25 + offset(Race2),
dat=lung,
cp.prism=0.02) # Big difference with default
prismFull$prism.plot
plotprism(prismFull)
# With Hierarchical Variable ADI4
# Needs all numerical variables (if 2 levels, 0 and 1)
# Note to Hannah: Dataset_flag seems okay as a factor... - OVERRULED
prismFullH <- prism(Surv(SmokeDuration, Case2) ~ Dataset_flag + Age + Gender + Education_harm + Smk_AgeStart_harm + SmokeStatus_harm + BMI + FmHx_LungCancer_harm + PHC_harm + PackYears + PM25 + offset(Race2),
dat=lungN,
hvar="ADI4",
cp.prism=0.02) # Big difference with default
