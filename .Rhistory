library(pROC)
library(gt)
# Reading in the Data
heart <- read.csv("./data/heart_failure_dataset.csv")
head(heart)
# Reading in the Data
heartOOS <- read.csv("./data/heart_failure_dataset_new_sample.csv")
head(heartOOS)
# Developing a Model
# If all interaction terms included, algorithm does not converge
fullmod <- glm(DEATH_EVENT ~ . + age:sex + smoking:sex + age:smoking + age:sex:smoking,
family = binomial(),
data = heart)
finmod <- step(fullmod, direction="backward", trace=0)
summary(finmod)
roc_in_sample <- pROC::roc(heart$DEATH_EVENT,
predict(finmod, newdata = heart, type = "response"))
roc_in_sample$auc
plot(roc_in_sample)
# Run k-fold cross validation
kfold <- function(seed, K) {
set.seed(seed)
fold_ids <- sample(rep(1:K, length=nrow(heart)))
aucs <- rep(list(numeric(0)), K)
for (i in 1:K){
test <- heart[fold_ids == i,]
train <- heart[fold_ids != i,]
# Evaluating
origmod <- glm(DEATH_EVENT ~ age + creatinine_phosphokinase +
ejection_fraction + serum_creatinine + smoking + age:smoking, family=binomial(), data = train)
proc <- pROC::roc(test$DEATH_EVENT,
predict(origmod, newdata = test, type = "response"))
aucs[i] <- proc$auc
# plot(proc)
}
return(aucs)
}
# Print out Comparison Results
comps <- function(k, aucs) {
row <- data.frame(K=k,
Mean=mean(as.numeric(aucs)),
Min=range(as.numeric(aucs))[1],
Max=range(as.numeric(aucs))[2],
Range=range(as.numeric(aucs))[2]-range(as.numeric(aucs))[1])
return(row)
}
myaucs <- kfold(7406, 10)
str(myaucs)
comps(10, myaucs)
comps_df <- data.frame(
K = numeric(),
Mean = numeric(),
Min = numeric(),
Max = numeric(),
Range = numeric()
)
for (i in 1:4) {
k = i*3
seed = c(7406, 123, 5)
for (x in 1:3) {
aucs <- kfold(seed[x], k)
mydf <- comps(k, aucs)
comps_df <- rbind(comps_df, mydf)
}
}
comps_df
# Run k-fold cross validation
kfold <- function(seed, K, data) {
set.seed(seed)
fold_ids <- sample(rep(1:K, length=nrow(data)))
aucs <- rep(list(numeric(0)), K)
for (i in 1:K){
test <- heart[fold_ids == i,]
train <- heart[fold_ids != i,]
# Evaluating
origmod <- glm(DEATH_EVENT ~ age + creatinine_phosphokinase +
ejection_fraction + serum_creatinine + smoking + age:smoking, family=binomial(), data = train)
proc <- pROC::roc(test$DEATH_EVENT,
predict(origmod, newdata = test, type = "response"))
aucs[i] <- proc$auc
# plot(proc)
}
return(aucs)
}
myaucs <- kfold(7406, 10, heart)
str(myaucs)
comps(10, myaucs)
myaucs1 <- kfold(7406, 10, heart)
myaucs2 <- kfold(7406, 10, heartOOS)
# str(myaucs)
c1 <- comps(10, "In Sample", myaucs1)
# Print out Comparison Results
comps <- function(k, S, aucs) {
row <- data.frame(Sample = S,
K=k,
Mean=mean(as.numeric(aucs)),
Min=range(as.numeric(aucs))[1],
Max=range(as.numeric(aucs))[2],
Range=range(as.numeric(aucs))[2]-range(as.numeric(aucs))[1])
return(row)
}
# str(myaucs)
c1 <- comps(10, "In Sample", myaucs1)
c2 <- comps(10, "Out of Sample", myacus2)
myaucs2 <- kfold(7406, 10, heartOOS)
c2 <- comps(10, "Out of Sample", myacus2)
c2 <- comps(10, "Out of Sample", myaucs2)
cbind(c1, c2)
rbind(c1, c2)
# Run k-fold cross validation
kfoldIS <- function(seed, K) {
set.seed(seed)
fold_ids <- sample(rep(1:K, length=nrow(heart)))
aucs <- rep(list(numeric(0)), K)
for (i in 1:K){
test <- heart[fold_ids == i,]
train <- heart[fold_ids != i,]
# Evaluating in sample
origmod <- glm(DEATH_EVENT ~ age + creatinine_phosphokinase +
ejection_fraction + serum_creatinine + smoking + age:smoking, family=binomial(), data = train)
proc <- pROC::roc(test$DEATH_EVENT,
predict(origmod, newdata = test, type = "response"))
aucs[i] <- proc$auc
}
return(aucs)
}
kfoldOOS <- function(seed, K) {
set.seed(seed)
fold_ids <- sample(rep(1:K, length=nrow(heart)))
aucs <- rep(list(numeric(0)), K)
for (i in 1:K){
# Evaluating in sample
origmod <- glm(DEATH_EVENT ~ age + creatinine_phosphokinase +
ejection_fraction + serum_creatinine + smoking + age:smoking, family=binomial(), data = heart)
proc <- pROC::roc(heartOOS$DEATH_EVENT,
predict(origmod, newdata = heartOOS, type = "response"))
aucs[i] <- proc$auc
}
return(aucs)
}
# Print out Comparison Results
comps <- function(k, S, aucs) {
row <- data.frame(Sample = S,
K=k,
Mean=mean(as.numeric(aucs)),
Min=range(as.numeric(aucs))[1],
Max=range(as.numeric(aucs))[2],
Range=range(as.numeric(aucs))[2]-range(as.numeric(aucs))[1])
return(row)
}
myaucs1 <- kfold(7406, 10, heart)
myaucs2 <- kfold(7406, 10, heartOOS)
# str(myaucs)
c1 <- comps(10, "In Sample", myaucs1)
c2 <- comps(10, "Out of Sample", myaucs2)
rbind(c1, c2)
myaucs1 <- kfoldIS(7406, 10)
myaucs2 <- kfoldOOS(7406, 10)
# str(myaucs)
c1 <- comps(10, "In Sample", myaucs1)
c2 <- comps(10, "Out of Sample", myaucs2)
rbind(c1, c2)
myaucs2
