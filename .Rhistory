#install.packages("remotes")
#remotes::install_github("yuhuilin619/prism")
download.file("https://github.com/yuhuilin619/prism/archive/refs/heads/master.zip", "prism_source.zip", mode = "wb")
unzip("prism_source.zip")
pkg_folder <- list.dirs(".", recursive = FALSE, full.names = FALSE)
pkg_folder <- pkg_folder[grepl("^prism-", pkg_folder)][1]
if (is.na(pkg_folder)) {
stop("Could not find the unzipped 'prism' folder. Check your working directory with getwd().")
}
r_files <- list.files(path = pkg_folder, pattern = "\\.[Rr]$", recursive = TRUE, full.names = TRUE)
for (f in r_files) {
lines <- readLines(f, warn = FALSE)
clean_lines <- iconv(lines, "UTF-8", "ASCII", sub = " ")
writeLines(clean_lines, f)
}
message(paste("Cleaned files in:", pkg_folder))
remotes::install_local(pkg_folder, force = TRUE, upgrade = "never")
